# SMTP settings for the /apply waitlist form.
# Works with Gmail (smtp.gmail.com:465 + app password) or Yandex
# (smtp.yandex.com:465 + app password). Port 465 = TLS; 587 = STARTTLS.
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465
SMTP_USER=your-address@yandex.com
SMTP_PASSWORD=your-app-password

# Destination address for new applications.
APPLY_TO_EMAIL=starknight@keepstar.one

# Neon Postgres connection string (SSL required).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
