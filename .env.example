# Postgres (Neon). SSL required.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# Auth.js — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://temporal-one-production.up.railway.app
AUTH_TRUST_HOST=true

# Google OAuth — Google Cloud Console → Credentials → Web application
# Authorized redirect URI: $AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram Login Widget — @BotFather
# After creating the bot, run /setdomain with the bot to allow the AUTH_URL host.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# SMTP — used by /api/apply and /api/interest. Works with Gmail (465 + app password)
# or Yandex (465 + app password). Port 465 = TLS; 587 = STARTTLS.
SMTP_HOST=smtp.yandex.com
SMTP_PORT=465
SMTP_USER=your-address@yandex.com
SMTP_PASSWORD=your-app-password
APPLY_TO_EMAIL=starknight@keepstar.one
